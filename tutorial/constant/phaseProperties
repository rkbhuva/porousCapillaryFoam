FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      phaseProperties;
}

phases              (electrolyte air);

air
{
    diameterModel   constant;
    constantCoeffs
    {
        d           8e-6;
    }

    residualAlpha   1e-6;
}

electrolyte
{
    diameterModel   constant;
    constantCoeffs
    {
        d           8e-6;
    }

    residualAlpha   1e-6;
}

blending
{
    default
    {
        type            linear;
        maxFullyDispersedAlpha.air 0.3;
        maxPartlyDispersedAlpha.air 0.5;
        maxFullyDispersedAlpha.electrolyte 0.3;
        maxPartlyDispersedAlpha.electrolyte 0.5;
    }
}

sigma
(
    (air and electrolyte)   0.0864106
);

aspectRatio
(
    (air in electrolyte)
    {
        type            constant;
        E0              1.0;
    }

    (electrolyte in air)
    {
        type            constant;
        E0              1.0;
    }
);

drag
(
    (air in electrolyte)
    {
        type            SchillerNaumann;
        residualRe      1e-3;
        swarmCorrection
        {
            type        none;
        }
    }

    (electrolyte in air)
    {
        type            SchillerNaumann;
        residualRe      1e-3;
        swarmCorrection
        {
            type        none;
        }
    }

    (air and electrolyte)
    {
        type            segregated;
        residualAlpha   1e-6;
        m               0.5;
        n               8;
        swarmCorrection
        {
            type        none;
        }
    }
);

virtualMass
(
    (air in electrolyte)
    {
        type            constantCoefficient;
        Cvm             0.5;
    }

    (electrolyte in air)
    {
        type            constantCoefficient;
        Cvm             0.5;
    }
);

heatTransfer
(

);

lift
(
);

wallLubrication
(
);

turbulentDispersion
(
);

pMin            10000;


